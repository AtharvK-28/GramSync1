{
  "name": "gramsync",
  "version": "1.0.0",
  "description": "Offline-first digital ledger for small merchants",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run tailwind\"",
    "server": "nodemon server/index.js",
    "tailwind": "npx tailwindcss -i ./client/css/app.css -o ./client/css/output.css --watch",
    "build": "npx tailwindcss -i ./client/css/app.css -o ./client/css/output.css --minify",
    "start": "node server/index.js",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "tailwindcss": "^3.4.0"
  }
}